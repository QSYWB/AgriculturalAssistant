# ===== DashScope (Aliyun Bailian) Configuration =====
# Get your API key from: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== LLM & Embedding Models =====
LLM_MODEL=qwen3-omni-flash
EMBEDDING_MODEL=text-embedding-v4

# ===== Tavily Search API =====
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ===== DeepSeek (Router/Supervisor意图分类专用) =====
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== JWT Configuration (optional) =====
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_HOURS=24

# ===== Rate Limiting (optional) =====
# RATE_LIMIT_PER_MINUTE=30
# RATE_LIMIT_PER_MINUTE_AUTH=60

# ===== MySQL Database =====
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=password
DB_NAME=agricultural_assistant
